# tmuxscout — tmux integration.
# This is a TEMPLATE: install.sh substitutes @SCOUT_BIN@ and writes tmuxscout.tmux
# (a tmux config is not a shell script, so the absolute path is baked in here).
# Keep it sourced AFTER your own window-status formatting so the markers win.

# Passive-notification counters (the status-right badge renders these — see README).
set -g @agent_waiting "0"
set -g @agent_done "0"

# Popup picker: prefix + <key> (key set via TMUXSCOUT_KEY, default "a")
bind @SCOUT_KEY@ display-popup -E -w 80% -h 70% "@SCOUT_BIN@ pick"

# Auto-clear a pane's alert when you focus it. Single outer quotes keep #{pane_id}
# literal so tmux expands it (with the focused pane as context) when the hook fires.
set -g focus-events on
set-hook -g pane-focus-in 'run-shell -b "@SCOUT_BIN@ clear #{pane_id}"'

# Status-bar alert marker (Catppuccin: waiting=red #f38ba8, done=green #a6e3a1).
# Prepends a colored dot to windows that have a flagged pane; edit the colors to taste.
set -g window-status-format "#{?#{==:#{@agent_win_alert},waiting},#[fg=#f38ba8]●#[fg=#6c7086] ,#{?#{==:#{@agent_win_alert},done},#[fg=#a6e3a1]●#[fg=#6c7086] ,}} #I:#W "
set -g window-status-current-format "#{?#{==:#{@agent_win_alert},waiting},#[fg=#f38ba8]●#[fg=#1e1e2e] ,#{?#{==:#{@agent_win_alert},done},#[fg=#a6e3a1]●#[fg=#1e1e2e] ,}} #I:#W "

# Highlight the current window. The formats above dropped tmux's default `#F`
# marker (which renders `*` next to the active window), so without a style the
# active window is visually identical to inactive ones. `reverse,bold` swaps
# fg/bg of whatever your status-style is — theme-neutral, no color hardcoded.
# Override in your ~/.tmux.conf AFTER `source-file …/tmuxscout.tmux` if you
# prefer a theme color (e.g. `set -g window-status-current-style 'fg=#1e1e2e,bg=#cba6f7,bold'`).
set -g window-status-current-style "reverse,bold"

# Default `status-right-length` is 40, which often truncates the badge when the
# user already has a clock / pane title / battery on the right. Bump it to a
# value that fits "⏳ NN ✅ NN" plus a typical right-side baseline. Conditional:
# only raise — never shrink a value the user set higher.
if-shell '[ "$(tmux show -gv status-right-length 2>/dev/null)" -lt 100 ]' 'set -g status-right-length 100'

# Passive badge: append the counters to status-right exactly once per server.
# Guarded by a user option so re-sourcing this file (or your ~/.tmux.conf)
# doesn't stack copies. To customize colors/position, paste the snippet
# (tmuxscout setup tmux --print) into your own status-right BEFORE sourcing
# this file — set -ag is skipped if @_tmuxscout_badge_installed is already 1.
%if "#{!=:#{@_tmuxscout_badge_installed},1}"
set -ag status-right "#{?@agent_waiting, #[fg=#1e1e2e]#[bg=#f38ba8]#[bold] ⏳ #{@agent_waiting} #[default],}#{?@agent_done, #[fg=#1e1e2e]#[bg=#a6e3a1]#[bold] ✅ #{@agent_done} #[default],}"
set -g @_tmuxscout_badge_installed 1
%endif
